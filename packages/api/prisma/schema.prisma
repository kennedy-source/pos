// ============================================================
// UniForm POS — Prisma Schema
// Database: PostgreSQL (cloud) / SQLite (local via separate schema)
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================================
// ENUMS
// ============================================================

enum UserRole {
  ADMIN
  MANAGER
  CASHIER
  STOREKEEPER
  EMBROIDERY_OPERATOR
}

enum Gender {
  MALE
  FEMALE
  UNISEX
}

enum StockTransactionType {
  STOCK_IN
  STOCK_OUT
  ADJUSTMENT
  DAMAGED
  LOST
  RETURNED
  SALE_DEDUCTION
  TRANSFER_IN
  TRANSFER_OUT
}

enum SaleStatus {
  DRAFT
  COMPLETED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum PaymentMethod {
  CASH
  MPESA
  BANK_TRANSFER
  MIXED
  CREDIT
}

enum PaymentStatus {
  PENDING
  PAID
  PARTIAL
  FAILED
  REFUNDED
}

enum EmbroideryStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  DELIVERED
  CANCELLED
}

enum EmbroideryPriority {
  NORMAL
  URGENT
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  SALE_COMPLETE
  SALE_CANCEL
  REFUND
  STOCK_ADJUST
  EMBROIDERY_STATUS_CHANGE
  PERMISSION_CHANGE
  SETTINGS_CHANGE
}

// ============================================================
// USERS & AUTH
// ============================================================

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  phone         String?
  passwordHash  String
  role          UserRole  @default(CASHIER)
  isActive      Boolean   @default(true)
  pin           String?   // 4-digit PIN for quick cashier login
  avatarUrl     String?
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  sales              Sale[]
  embroideryJobs     EmbroideryJob[]      @relation("OperatorJobs")
  auditLogs          AuditLog[]
  stockTransactions  InventoryTransaction[]
  refreshTokens      RefreshToken[]
  createdProducts    Product[]            @relation("ProductCreator")
  cashierShifts      CashierShift[]

  @@index([email])
  @@index([role])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?
  deviceInfo String?

  @@index([token])
  @@index([userId])
}

model CashierShift {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id])
  openingCash     Decimal  @db.Decimal(12, 2)
  closingCash     Decimal? @db.Decimal(12, 2)
  openedAt        DateTime @default(now())
  closedAt        DateTime?
  notes           String?
  sales           Sale[]

  @@index([userId])
  @@index([openedAt])
}

// ============================================================
// SCHOOLS & CATEGORIES
// ============================================================

model School {
  id          String    @id @default(cuid())
  name        String    @unique
  code        String    @unique // e.g. "NAIROBI_ACADEMY"
  address     String?
  contactName String?
  contactPhone String?
  logoUrl     String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  products        Product[]
  customers       Customer[]
  embroideryJobs  EmbroideryJob[]

  @@index([name])
  @@index([code])
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique  // e.g. "Shirts", "Trousers", "Bags"
  description String?
  createdAt   DateTime  @default(now())

  products Product[]

  @@index([name])
}

model Supplier {
  id          String    @id @default(cuid())
  name        String
  contactName String?
  phone       String?
  email       String?
  address     String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())

  products Product[]

  @@index([name])
}

// ============================================================
// PRODUCTS & INVENTORY
// ============================================================

model Product {
  id            String   @id @default(cuid())
  name          String
  sku           String   @unique
  barcode       String?  @unique
  description   String?
  categoryId    String
  category      Category @relation(fields: [categoryId], references: [id])
  schoolId      String?  // null = generic product, not school-specific
  school        School?  @relation(fields: [schoolId], references: [id])
  supplierId    String?
  supplier      Supplier? @relation(fields: [supplierId], references: [id])
  createdById   String
  createdBy     User     @relation("ProductCreator", fields: [createdById], references: [id])

  gender        Gender   @default(UNISEX)
  imageUrl      String?
  isActive      Boolean  @default(true)
  isBundle      Boolean  @default(false)  // true = this product is a bundle of others
  notes         String?

  costPrice     Decimal  @db.Decimal(10, 2)
  sellingPrice  Decimal  @db.Decimal(10, 2)
  reorderLevel  Int      @default(5)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  variants          ProductVariant[]
  saleItems         SaleItem[]
  inventoryTxns     InventoryTransaction[]
  bundleItems       BundleItem[]           @relation("BundleParent")
  bundleOf          BundleItem[]           @relation("BundleChild")
  stockAlerts       StockAlert[]
  embroideryItems   EmbroideryJobItem[]

  @@index([sku])
  @@index([barcode])
  @@index([categoryId])
  @@index([schoolId])
  @@index([name])
}

model ProductVariant {
  id            String   @id @default(cuid())
  productId     String
  product       Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  size          String?  // e.g. "S", "M", "L", "XL", "28", "30"
  color         String?  // e.g. "Navy Blue", "White"
  sku           String   @unique  // variant-specific SKU
  barcode       String?  @unique
  costPrice     Decimal? @db.Decimal(10, 2)  // override parent if different
  sellingPrice  Decimal? @db.Decimal(10, 2)
  currentStock  Int      @default(0)
  reorderLevel  Int?     // override parent if different
  imageUrl      String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  saleItems         SaleItem[]
  inventoryTxns     InventoryTransaction[]
  stockAlerts       StockAlert[]
  embroideryItems   EmbroideryJobItem[]

  @@index([productId])
  @@index([sku])
  @@index([barcode])
  @@index([size, color])
}

model BundleItem {
  id         String  @id @default(cuid())
  bundleId   String
  bundle     Product @relation("BundleParent", fields: [bundleId], references: [id])
  itemId     String
  item       Product @relation("BundleChild", fields: [itemId], references: [id])
  quantity   Int     @default(1)

  @@unique([bundleId, itemId])
}

model InventoryTransaction {
  id              String               @id @default(cuid())
  productId       String?
  product         Product?             @relation(fields: [productId], references: [id])
  variantId       String?
  variant         ProductVariant?      @relation(fields: [variantId], references: [id])
  type            StockTransactionType
  quantity        Int                  // positive = in, negative = out
  quantityBefore  Int
  quantityAfter   Int
  unitCost        Decimal?             @db.Decimal(10, 2)
  totalValue      Decimal?             @db.Decimal(12, 2)
  reason          String?
  reference       String?              // e.g. sale ID, PO number
  performedById   String
  performedBy     User                 @relation(fields: [performedById], references: [id])
  createdAt       DateTime             @default(now())
  notes           String?

  @@index([productId])
  @@index([variantId])
  @@index([type])
  @@index([createdAt])
  @@index([performedById])
}

model StockAlert {
  id          String         @id @default(cuid())
  productId   String?
  product     Product?       @relation(fields: [productId], references: [id])
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  currentQty  Int
  reorderLevel Int
  isResolved  Boolean        @default(false)
  resolvedAt  DateTime?
  createdAt   DateTime       @default(now())

  @@index([isResolved])
  @@index([productId])
}

// ============================================================
// CUSTOMERS
// ============================================================

model Customer {
  id              String   @id @default(cuid())
  name            String
  phone           String?  @unique
  email           String?
  schoolId        String?
  school          School?  @relation(fields: [schoolId], references: [id])
  creditBalance   Decimal  @db.Decimal(10, 2) @default(0)  // negative = owes money
  creditLimit     Decimal  @db.Decimal(10, 2) @default(0)
  totalPurchases  Decimal  @db.Decimal(12, 2) @default(0)
  visitCount      Int      @default(0)
  notes           String?
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  sales          Sale[]
  embroideryJobs EmbroideryJob[]

  @@index([phone])
  @@index([name])
  @@index([schoolId])
}

// ============================================================
// SALES & POS
// ============================================================

model Sale {
  id              String        @id @default(cuid())
  receiptNumber   String        @unique  // e.g. "UNI-2024-001234"
  customerId      String?
  customer        Customer?     @relation(fields: [customerId], references: [id])
  cashierId       String
  cashier         User          @relation(fields: [cashierId], references: [id])
  shiftId         String?
  shift           CashierShift? @relation(fields: [shiftId], references: [id])

  status          SaleStatus    @default(DRAFT)
  paymentStatus   PaymentStatus @default(PENDING)
  paymentMethod   PaymentMethod @default(CASH)

  subtotal        Decimal       @db.Decimal(12, 2)
  discountAmount  Decimal       @db.Decimal(12, 2) @default(0)
  taxAmount       Decimal       @db.Decimal(12, 2) @default(0)
  totalAmount     Decimal       @db.Decimal(12, 2)
  amountPaid      Decimal       @db.Decimal(12, 2) @default(0)
  changeGiven     Decimal       @db.Decimal(12, 2) @default(0)

  notes           String?
  completedAt     DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  // Relations
  items           SaleItem[]
  payments        Payment[]
  returns         Return[]
  embroideryJobs  EmbroideryJob[]  // jobs linked to this sale

  @@index([receiptNumber])
  @@index([cashierId])
  @@index([customerId])
  @@index([status])
  @@index([createdAt])
  @@index([paymentMethod])
}

model SaleItem {
  id            String         @id @default(cuid())
  saleId        String
  sale          Sale           @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId     String
  product       Product        @relation(fields: [productId], references: [id])
  variantId     String?
  variant       ProductVariant? @relation(fields: [variantId], references: [id])
  quantity      Int
  unitPrice     Decimal        @db.Decimal(10, 2)
  costPrice     Decimal        @db.Decimal(10, 2)
  discountAmt   Decimal        @db.Decimal(10, 2) @default(0)
  lineTotal     Decimal        @db.Decimal(12, 2)
  notes         String?

  @@index([saleId])
  @@index([productId])
}

model Payment {
  id              String        @id @default(cuid())
  saleId          String
  sale            Sale          @relation(fields: [saleId], references: [id])
  method          PaymentMethod
  amount          Decimal       @db.Decimal(12, 2)
  mpesaCode       String?       // M-Pesa transaction code
  mpesaPhone      String?       // phone number used for M-Pesa
  mpesaReceiptNo  String?
  bankRef         String?
  status          PaymentStatus @default(PENDING)
  paidAt          DateTime?
  createdAt       DateTime      @default(now())

  @@index([saleId])
  @@index([mpesaCode])
  @@index([status])
}

model Return {
  id              String   @id @default(cuid())
  saleId          String
  sale            Sale     @relation(fields: [saleId], references: [id])
  reason          String
  refundAmount    Decimal  @db.Decimal(12, 2)
  refundMethod    PaymentMethod
  restockItems    Boolean  @default(true)
  processedById   String
  notes           String?
  createdAt       DateTime @default(now())

  returnItems ReturnItem[]

  @@index([saleId])
}

model ReturnItem {
  id         String  @id @default(cuid())
  returnId   String
  return     Return  @relation(fields: [returnId], references: [id])
  saleItemId String
  quantity   Int
  reason     String?

  @@index([returnId])
}

// ============================================================
// EMBROIDERY JOBS
// ============================================================

model EmbroideryJob {
  id              String             @id @default(cuid())
  jobNumber       String             @unique  // e.g. "EMB-2024-0089"
  customerId      String?
  customer        Customer?          @relation(fields: [customerId], references: [id])
  schoolId        String?
  school          School?            @relation(fields: [schoolId], references: [id])
  saleId          String?            // linked to a sale if uniforms were also purchased
  sale            Sale?              @relation(fields: [saleId], references: [id])
  operatorId      String?
  operator        User?              @relation("OperatorJobs", fields: [operatorId], references: [id])

  // Customer info (for walk-in/external)
  customerName    String
  customerPhone   String?

  status          EmbroideryStatus   @default(PENDING)
  priority        EmbroideryPriority @default(NORMAL)

  designName      String             // Logo/design name
  designRef       String?            // file path or reference code
  threadColors    String             // comma-separated colors e.g. "Navy,Gold,White"

  totalItems      Int                // number of garments
  pricePerItem    Decimal            @db.Decimal(10, 2)
  totalCost       Decimal            @db.Decimal(12, 2)
  depositPaid     Decimal            @db.Decimal(12, 2) @default(0)
  balanceDue      Decimal            @db.Decimal(12, 2) @default(0)

  receivedDate    DateTime           @default(now())
  dueDate         DateTime
  startedAt       DateTime?
  completedAt     DateTime?
  deliveredAt     DateTime?

  notes           String?
  internalNotes   String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  items           EmbroideryJobItem[]
  statusHistory   EmbroideryStatusLog[]

  @@index([jobNumber])
  @@index([status])
  @@index([customerId])
  @@index([operatorId])
  @@index([dueDate])
  @@index([saleId])
}

model EmbroideryJobItem {
  id          String         @id @default(cuid())
  jobId       String
  job         EmbroideryJob  @relation(fields: [jobId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product?       @relation(fields: [productId], references: [id])
  variantId   String?
  variant     ProductVariant? @relation(fields: [variantId], references: [id])
  garmentType String         // "Shirt", "Blazer", etc — free text if no product
  quantity    Int
  size        String?
  color       String?
  logoPosition String?       // "Left chest", "Back", "Both"
  notes       String?

  @@index([jobId])
}

model EmbroideryStatusLog {
  id          String           @id @default(cuid())
  jobId       String
  job         EmbroideryJob    @relation(fields: [jobId], references: [id])
  fromStatus  EmbroideryStatus?
  toStatus    EmbroideryStatus
  changedById String
  notes       String?
  createdAt   DateTime         @default(now())

  @@index([jobId])
}

// ============================================================
// AUDIT LOGS
// ============================================================

model AuditLog {
  id          String      @id @default(cuid())
  userId      String?
  user        User?       @relation(fields: [userId], references: [id])
  action      AuditAction
  entity      String      // table name e.g. "Sale", "Product"
  entityId    String?     // record ID
  oldData     Json?       // snapshot before change
  newData     Json?       // snapshot after change
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime    @default(now())

  @@index([userId])
  @@index([action])
  @@index([entity, entityId])
  @@index([createdAt])
}

// ============================================================
// SETTINGS
// ============================================================

model Setting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@index([key])
}

// ============================================================
// SYNC (for offline-first local DB reconciliation)
// ============================================================

model SyncLog {
  id            String   @id @default(cuid())
  entityType    String
  entityId      String
  operation     String   // INSERT | UPDATE | DELETE
  payload       Json
  syncedAt      DateTime?
  failureReason String?
  deviceId      String?
  createdAt     DateTime @default(now())

  @@index([syncedAt])
  @@index([entityType])
}
