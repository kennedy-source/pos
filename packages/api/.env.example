# ============================================================
# UniForm POS — API Environment Configuration
# Copy this to .env and fill in real values
# ============================================================

# Server
NODE_ENV=development
PORT=4000

# Database (PostgreSQL — cloud)
DATABASE_URL="postgresql://uniformpos:your_password@localhost:5432/uniformpos_db"

# Authentication
JWT_SECRET=change-this-to-a-strong-random-secret-min-32-chars
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_DAYS=30

# Frontend origins
WEB_ADMIN_URL=http://localhost:3001

# M-Pesa Daraja API (Safaricom Kenya)
# Get these from https://developer.safaricom.co.ke
MPESA_CONSUMER_KEY=your_consumer_key_here
MPESA_CONSUMER_SECRET=your_consumer_secret_here
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919
MPESA_CALLBACK_URL=https://your-api-domain.com
# Use sandbox for testing, production for live:
# Sandbox: https://sandbox.safaricom.co.ke
# Production: https://api.safaricom.co.ke
MPESA_ENV=sandbox

# File storage (optional — for product images)
# CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# Backup (optional)
# BACKUP_S3_BUCKET=uniform-pos-backups
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=af-south-1
